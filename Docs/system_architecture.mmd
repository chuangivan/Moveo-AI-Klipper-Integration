---
config:
  layout: elk
---
flowchart TB
 subgraph PowerLayer["⚡ Power Delivery"]
    direction LR
        PSU["Mean Well LRS-350-36<br>36V / 350W"]
        Buck5V["Buck Converter<br>36V to 5V / 20A"]
        Buck24V["Buck Converter<br>36V to 24V / 5A"]
  end
 subgraph ComputeLayer["🧠 Control & AI Brain"]
    direction LR
        Pi5["Raspberry Pi 5 8GB<br>Mainsail, OpenAI API, DOA"]
        Spider["FYSETC Spider V3.0 H723<br>Klipper MCU"]
  end
 subgraph SensorLayer["👀 AI Sensors"]
    direction TB
        Mic["XMOS XVF3800 Mic Array"]
        Cam["Astra Pro Plus RGB-D"]
        Lidar["RPLIDAR A1"]
  end
 subgraph ExtDrive["🦾 External High-Voltage Drives (36V)"]
    direction TB
        DM1["DM556Y"]
        DM2L["DM556Y"]
        DM2R["DM556Y"]
        M1(("Ax 1: Base Nema 17"))
        M2L(("Ax 2: Shoulder L Nema 23 + 1:10 Gear"))
        M2R(("Ax 2: Shoulder R Nema 23 + 1:10 Gear"))
  end
 subgraph IntDrive["🦾 Onboard Silent Drives (SPI)"]
    direction TB
        TMC["3x TMC2240<br>Onboard SPI"]
        M3(("Ax 3: Elbow Nema 17 + 1:19 Gear"))
        M4(("Ax 4: Wrist Nema 17"))
        M5(("Ax 5: Wrist Nema 17"))
        Servo["Gripper Servo"]
  end
    PSU == 36V Direct ==> DM1 & DM2L & DM2R & TMC
    PSU == 36V Step-down ==> Buck5V & Buck24V
    Buck5V == 5V via GPIO Header ==> Pi5
    Buck24V == 24V Logic & Brake Power ==> Spider
    Mic <== "USB / USB 3.0 Data" ==> Pi5
    Cam <== "USB / USB 3.0 Data" ==> Pi5
    Lidar <== "USB / USB 3.0 Data" ==> Pi5
    Pi5 <== USB Data ==> Spider
    Spider -. 5V Pulse/Dir Common Anode .-> DM1 & DM2L & DM2R
    Spider -. SPI Bus Communication .-> TMC
    Spider -. 24V MOS Brake Control .-> M2L & M2R
    Spider -. 5V PWM .-> Servo
    DM1 == Power Phase ===> M1
    DM2L == Power Phase ===> M2L
    DM2R == Power Phase ===> M2R
    TMC == Power Phase ===> M3 & M4 & M5

     PSU:::power
     Buck5V:::power
     Buck24V:::power
     Pi5:::compute
     Spider:::compute
     Mic:::ai
